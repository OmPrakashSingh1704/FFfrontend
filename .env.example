# =============================================================================
# FoundersLib Frontend — Environment Variables
# =============================================================================
# Copy this file to `.env.local` (or `.env.production` for prod builds)
# and fill in your values. NEVER commit the populated file.
#
# Vite reads VITE_* at BUILD TIME, not runtime. After changing any value
# here you must rebuild (`npm run build`) for the new value to take effect.
# In dev (`npm run dev`) the dev server picks up changes on restart.
# =============================================================================


# -----------------------------------------------------------------------------
# Backend API                                                          [REQUIRED]
# -----------------------------------------------------------------------------
# Where the frontend sends API requests. No trailing slash.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Use cookie-based auth instead of bearer tokens. Leave 'false' unless you
# have a backend cookie-session setup.
VITE_API_USE_COOKIES=false


# -----------------------------------------------------------------------------
# Anti-Abuse — Cloudflare Turnstile (signup captcha)                  [REQUIRED in prod]
# -----------------------------------------------------------------------------
# Public site key (the secret key belongs in the BACKEND env, never here).
# Get it at https://dash.cloudflare.com/ → Turnstile → your site.
# Leave blank in dev → widget doesn't render, captcha skipped end-to-end.
VITE_TURNSTILE_SITE_KEY=


# -----------------------------------------------------------------------------
# Error Tracking — Sentry                                             [PER-FEATURE]
# -----------------------------------------------------------------------------
# Sentry DSN for browser-side error capture. Blank disables Sentry.
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Pipe console.error/warn through Sentry too (off by default — noisy).
VITE_CAPTURE_CONSOLE_ERRORS=false


# -----------------------------------------------------------------------------
# Status Page (optional)                                              [PER-FEATURE]
# -----------------------------------------------------------------------------
# Public status page URL shown in the app footer. No trailing slash.
# VITE_STATUS_PAGE_URL=https://status.founderslib.in

# Better Stack status summary JSON endpoint (used to render a live indicator).
# VITE_STATUS_PAGE_SUMMARY_URL=https://uptime.betterstack.com/api/v2/status_pages/<slug>/summary
